{
    "welcomeFile": "/productui-1.0.0/index.html",
    "authenticationMethod": "route",
    "routes": [
        {
            "source": "^/product/(.*)$",
            "target": "/product/$1",
            "destination": "srv-api",
            "authenticationType": "xsuaa",
            "csrfProtection": false
        },
        {
            "source": "^(.*)$",
            "target": "$1",
            "service": "html5-apps-repo-rt",
            "authenticationType": "xsuaa"
        }
    ]
}